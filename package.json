{
  "name": "generic-snmp",
  "version": "3.1.1",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "postinstall": "husky",
    "format": "prettier -w .",
    "package": "run build && companion-module-build",
    "build": "rimraf dist && run build:main",
    "build:main": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint:raw": "eslint",
    "lint": "run lint:raw .",
    "test": "vitest --run"
  },
  "dependencies": {
    "@companion-module/base": "~2.1.1",
    "es-toolkit": "^1.49.0",
    "net-snmp": "^3.26.3",
    "p-queue": "^9.3.0"
  },
  "devDependencies": {
    "@companion-module/tools": "^3.0.2",
    "@types/net-snmp": "^3.23.0",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "^3.8.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "^26.4.0"
  },
  "license": "ISC",
  "lint-staged": {
    "*.{css,json,md,scss}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "yarn lint:raw --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitfocus/companion-module-generic-snmp.git"
  },
  "prettier": "@companion-module/tools/.prettierrc.json",
  "packageManager": "yarn@4.17.0"
}
